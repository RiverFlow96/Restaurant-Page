compatibility_date = "2024-01-01"

[site]
bucket = "frontend/dist"

[build]
command = "bun run build"
directory = "frontend/dist"

[[redirects]]
from = "/*"
status = 200

[[headers]]
for = "/api/*"
backend = "https://your-backend.onrender.com"

[[headers]]
for = "/admin/*"
backend = "https://your-backend.onrender.com"