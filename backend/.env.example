# ==========================================
# CONFIGURACIÓN DE ENTORNO
# ==========================================
# Copia este archivo a .env y completa los valores

# ==========================================
# DJANGO SETTINGS
# ==========================================
DEBUG=False
SECRET_KEY=your-super-secret-key-change-in-production-min-50-chars
ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# ==========================================
# DATABASE (SQLite local)
# ==========================================
DATABASE_URL=db.sqlite3

# ==========================================
# DATABASE (Supabase/PostgreSQL) - Descomenta para usar PostgreSQL
# ==========================================
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=your-postgres-password
# DB_HOST=db.xxxx.supabase.co
# DB_PORT=5432

# ==========================================
# CORS
# ==========================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-domain.com,https://www.your-domain.com

# ==========================================
# MEDIA FILES
# ==========================================
MEDIA_URL=/media/
MEDIA_ROOT=backend/media

# ==========================================
# RENDER DEPLOYMENT
# ==========================================
# PORT=8000

# ==========================================
# CLOUDFLARE FRONTEND
# ==========================================
VITE_API_URL=https://your-backend.onrender.com
VITE_APP_URL=https://your-domain.com